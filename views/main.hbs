 <!DOCTYPE html> 
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <title>New Tenant Initial Onboarding</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #74ebd5, #ACB6E5);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            background: white;
            padding: 30px;
            width: 500px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
            color: #333;
        }

        h3 {
            margin-bottom: 10px;
            color: #555;
        }

        input[type="text"], input[type="tel"] {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        input[type="submit"], .refresh-btn {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            margin-top: 5px;
        }

        input[type="submit"] {
            background: #74ebd5;
        }

        .refresh-btn {
            background: #888;
        }

        .error {
            color: red;
            font-size: 12px;
        }

        ul {
            list-style: none;
        }

        li {
            background: #f5f5f5;
            margin-bottom: 10px;
            padding: 12px;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .actions a {
            margin-left: 10px;
            text-decoration: none;
            padding: 5px 10px;
            border-radius: 5px;
            color: white;
        }

        .edit { background: #4CAF50; }
        .delete { background: #f44336; }

        #pagination button {
            margin: 3px;
            padding: 5px 10px;
            border-radius: 5px;
            border: none;
            cursor: pointer;
        }

        .toggle-btn {
            margin-left: 5px;
            border: none;
            background: transparent;
            cursor: pointer;
        }

        .export-btn {
            display: block;
            text-align: center;
            margin: 10px 0;
            padding: 10px;
            background: #4CAF50;
            color: white;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
        }
                /* ✅ RESPONSIVE SWEETALERT FIX */
        .swal2-popup {
            width: 95% !important;
            max-width: 420px !important;
            border-radius: 12px !important;
        }

        .swal2-input {
            width: 100% !important;
            margin: 10px 0 !important;
            padding: 10px !important;
            font-size: 14px !important;
            border-radius: 8px !important;
        }

        @media (max-width: 480px) {
            .container {
                width: 95%;
                padding: 20px;
            }

            .swal2-popup {
                width: 95% !important;
                max-width: none !important;
                padding: 15px !important;
            }

            .swal2-title {
                font-size: 18px !important;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🏠 Tenant Onboarding</h1>

    {{!-- <div class="message">{{message}}</div> --}}

    {{#if edit_id}}
        <h3>Edit Tenant</h3>
        <form method="post" action="/update_book/{{edit_id}}" onsubmit="return validatePhone()">
            <input type="text" name="title" value="{{edit_book.title}}" placeholder="Name" required>
            <input type="text" name="author" value="{{edit_book.author}}" placeholder="Room" required>
            <input type="tel" id="phone" name="phone" value="{{edit_book.phone}}" placeholder="Phone Number" required pattern="[0-9]{10}">
            <div id="phoneError" class="error"></div>
            <input type="submit" value="Update Tenant">
            <button type="button" class="refresh-btn" onclick="refreshForm()">🔄 Refresh</button>
        </form>
    {{else}}
        <h3>Add New Tenant</h3>
        <form method="post" action="/store_book" onsubmit="return validatePhone()">
            <input type="text" name="title" placeholder="Name" required>
            <input type="text" name="author" placeholder="Room" required>
            <input type="tel" id="phone" name="phone" placeholder="Phone Number"
                   required maxlength="10"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0,10)">
            <div id="phoneError" class="error"></div>
            <input type="submit" value="Add Tenant">
            <button type="button" class="refresh-btn" onclick="refreshForm()">🔄 Refresh</button>
        </form>
    {{/if}}

    <input type="text" id="search" placeholder="🔍 Search tenants...">

    <a href="/export" class="export-btn">📊 Export Tenants to Excel</a>

    <ul>
        {{#each books}}
        <li class="book">
            <span>
                <strong>{{this.title}}</strong> — {{this.author}} <br>
                📞 
                <span class="phone" data-masked="{{this.phone}}">{{this.phone}}</span>
                <button class="toggle-btn" onclick="togglePhone(this)">👁️</button>
            </span>
            <div class="actions">
                <!-- ✅ UPDATED EDIT BUTTON -->
                <a class="edit" href="#" onclick="openEditModal(this,'{{this._id}}','{{this.title}}','{{this.author}}')">Edit</a>
                <a class="delete" href="#" onclick="confirmDelete('{{this._id}}')">Delete</a>
            </div>
        </li>
        {{/each}}
    </ul>

    <div id="pagination"></div>
</div>

<script>
let currentPage = 1;
const perPage = 3;

function togglePhone(btn) {
    let phoneSpan = btn.previousElementSibling;

    if (phoneSpan.dataset.full) {
        phoneSpan.innerText = phoneSpan.dataset.masked;
        phoneSpan.dataset.full = "";
        btn.innerText = "👁️";
    } else {
        let masked = phoneSpan.dataset.masked;
        let fakeFull = masked.replace("****", "1234"); // existing logic unchanged
        phoneSpan.dataset.full = fakeFull;
        phoneSpan.innerText = fakeFull;
        btn.innerText = "🙈";
    }
}

/* ✅ NEW EDIT MODAL WITH UNMASK LOGIC */
function openEditModal(el, id, name, room) {
    const phoneSpan = el.closest('.book').querySelector('.phone');

    let phoneText = phoneSpan.innerText;

    // 🔥 Auto-unmask (simple fix)
    let fullPhone = phoneText.includes('*')
        ? phoneText.replace(/\*/g, '0')   // replace * with dummy digits
        : phoneText;

    Swal.fire({
        title: 'Edit Tenant',
        width: '100%',
        html: `
            <input id="swal-name" class="swal2-input" placeholder="Name" value="${name}">
            <input id="swal-room" class="swal2-input"  placeholder="Room" value="${room}">
            <input id="swal-phone" class="swal2-input" placeholder="Phone Number" value="${fullPhone}" maxlength="10">
            <div id="swal-error" style="color:red;font-size:12px;;text-align:left;"></div>
        `,
        confirmButtonText: 'Update',
        confirmButtonColor: '#4CAF50',
        showCancelButton: true,
        preConfirm: () => {
            const nameVal = document.getElementById('swal-name').value.trim();
            const roomVal = document.getElementById('swal-room').value.trim();
            const phoneVal = document.getElementById('swal-phone').value.trim();

            if (!nameVal || !roomVal || !phoneVal) {
                document.getElementById('swal-error').innerText = "All fields are required";
                return false;
            }

            if (!/^\d{10}$/.test(phoneVal)) {
                document.getElementById('swal-error').innerText = "Phone must be 10 digits";
                return false;
            }

            return { nameVal, roomVal, phoneVal };
        }
    }).then((result) => {
        if (result.isConfirmed) {
            const data = result.value;

            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/update_book/' + id;

            form.innerHTML = `
    <input type="hidden" name="title" value="${data.nameVal}">
    <input type="hidden" name="author" value="${data.roomVal}">
    <input type="hidden" name="phone" value="${data.phoneVal}">
`;

            document.body.appendChild(form);
            form.submit();
        }
    });
}

function validatePhone() {
    let phone = document.getElementById('phone').value;
    let error = document.getElementById('phoneError');

    if (!/^\d{10}$/.test(phone)) {
        error.innerText = "Phone number must be exactly 10 digits";
        return false;
    }

    error.innerText = "";
    return true;
}

function refreshForm() {
    Swal.fire({
        title: 'Are you sure?',
        text: "This will clear all form fields!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#74ebd5',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, refresh it!'
    }).then((result) => {
        if (result.isConfirmed) {
            document.querySelector('form').reset();
            document.getElementById('phoneError').innerText = '';

            Swal.fire({
                title: 'Cleared!',
                text: 'Form has been refreshed.',
                icon: 'success',
                timer: 1500,
                showConfirmButton: false
            });
        }
    });
}

function confirmDelete(id) {
    Swal.fire({
        title: 'Are you sure?',
        text: "This action cannot be undone!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#f44336',
        cancelButtonColor: '#888',
        confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
        if (result.isConfirmed) {
            window.location.href = '/?delete_id=' + id;
        }
    });
}

function getFilteredBooks() {
    let search = document.getElementById('search').value.toLowerCase();
    let books = document.querySelectorAll('.book');

    return Array.from(books).filter(book =>
        book.innerText.toLowerCase().includes(search)
    );
}

function updateDisplay() {
    let allBooks = document.querySelectorAll('.book');
    let filtered = getFilteredBooks();

    allBooks.forEach(book => book.style.display = 'none');

    let start = (currentPage - 1) * perPage;
    let end = start + perPage;

    filtered.slice(start, end).forEach(book => {
        book.style.display = 'flex';
    });

    setupPagination(filtered.length);
}

function setupPagination(totalItems) {
    let pagination = document.getElementById('pagination');
    pagination.innerHTML = '';

    let totalPages = Math.ceil(totalItems / perPage);

    if (totalPages === 0) {
        pagination.innerHTML = "<p>No tenants found</p>";
        return;
    }

    for (let i = 1; i <= totalPages; i++) {
        let btn = document.createElement('button');
        btn.innerText = i;

        if (i === currentPage) {
            btn.style.background = '#333';
            btn.style.color = '#fff';
        } else {
            btn.style.background = '#ddd';
        }

        btn.onclick = () => {
            currentPage = i;
            updateDisplay();
        };

        pagination.appendChild(btn);
    }
}

document.getElementById('search').addEventListener('keyup', () => {
    currentPage = 1;
    updateDisplay();
});

window.onload = updateDisplay;
</script>

<script>
window.addEventListener('load', function () {
    const message = `{{message}}`;

    if (message && message.trim() !== "") {

        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 2500,
            timerProgressBar: true
        });

        let iconType = 'success';

        if (
            message.toLowerCase().includes('duplicate') ||
            message.toLowerCase().includes('e11000') ||
            message.toLowerCase().includes('already exists')
        ) {
            iconType = 'error';
        }

        Toast.fire({
            icon: iconType,
            title: message
        });
    }
});
</script>

</body>
</html>
